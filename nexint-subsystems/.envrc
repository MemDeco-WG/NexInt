# 1. 自动同步子模块指针
echo "Checking Submodules..."
git submodule update --init --recursive

# 2. 定义快捷别名 (内核开发常用命令)
# 同步所有子模块到各自的远程分支最新版
alias nexint-sync='git submodule update --remote --merge'

# 批量推送所有子模块的 commit (如果本地有更新)
alias nexint-push='git submodule foreach "git push origin main || true"'

# 批量拉取所有子模块
alias nexint-pull='git submodule foreach "git pull origin main"'

# 3. 检查 Workspace 健康度
cargo check --workspace
